                            "raw": "{\n    \"country_id\": 1,\n    \"description\": \"A beautiful trip to the mountains.\",\n    \"start_date\": \"2025-10-01\",\n    \"end_date\": \"2025-10-10\",\n    \"price\": 1999.99,\n    \"image_file_name\": \"mountains.jpg\"\n}"
